# Copy to .env and adjust. Never commit the real .env.

ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://trading:trading@db:5432/trading

# Redis
REDIS_URL=redis://redis:6379/0

# Security — generate strong values for any non-dev use.
# scripts/setup.sh will generate these for you.
MASTER_KEY=dev-insecure-master-key-change-me
JWT_SECRET=dev-insecure-jwt-secret-change-me

# Trading safety: live trading is opt-in only. Keep paper default on.
PAPER_TRADING_DEFAULT=true

# Frontend -> backend API base URL (browser-reachable).
NEXT_PUBLIC_API_URL=http://localhost:8000
